{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./", // src yerine kök dizin yaptık
    "types": ["node"]
  },
  "include": ["src/**/*"] // Dosyayı buraya ekledik!
}